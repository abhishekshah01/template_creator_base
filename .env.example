# Environment: "dev" or "local"
TEMPLATE_ENV=dev

# Database connection (to look up env_id from job_id)
DB_DSN=host=localhost port=7432 dbname=postgres user=postgres

# Envcore URL (for running commands inside pods)
ENVCORE_URL=http://envcore.int-worker.dev.emergentagent.com

# Emergent API (for pause-environment)
EMERGENT_API_URL=https://api.dev.emergentagent.com

# Dev VM details
VM_HOST=emergent-dev-vm-anshul
VM_ZONE=us-central1-a

# Optional: SSH key for deployed backends (leave empty for local gcloud auth)
VM_USER=
VM_SSH_KEY=

# Template defaults
RESTIC_PASSWORD=test123
DEST_BUCKET=emergent-dev-template-restic
SOURCE_BUCKET=dev-snapshots-restic
