# Copy this file to backend/.env and fill in the values.
# All values here are placeholders — do NOT commit the real .env.

# --- App's own MongoDB (used for persistence) ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=template_creator_dev   # Use template_creator_prod for prod deployments

# --- Deployment scope (dev | prod) ---
# Controls which environments are available in this deployment.
# "dev"  → dev + ephemeral environments (internal dev/eph URLs reachable)
# "prod" → prod environment only (internal prod URLs reachable)
DEPLOYMENT_SCOPE=dev

# --- Active environment (dev | prod | eph-<name>) ---
TEMPLATE_ENV=eph-leadgen1

# --- Ephemeral environment URL templates ({name} is substituted) ---
EPH_API_URL_TEMPLATE=
EPH_ENVCORE_URL=
EPH_PAUSE_URL_TEMPLATE=
EPH_DB_DSN_TEMPLATE=

# --- Standard environments ---
DEV_API_URL=
DEV_ENVCORE_URL=
DEV_PAUSE_URL=
DEV_DB_DSN=

PROD_API_URL=
PROD_ENVCORE_URL=
PROD_PAUSE_URL=
PROD_DB_DSN=

# --- Template creation (restic + GCS) ---
# Buckets and passwords are scope-aware: the app picks the pair matching DEPLOYMENT_SCOPE.
# Unscoped SOURCE_BUCKET / DEST_BUCKET / RESTIC_PASSWORD still win if set (one-off overrides).
DEV_RESTIC_SOURCE_BUCKET=dev-snapshots-restic
DEV_RESTIC_DEST_BUCKET=emergent-dev-template-restic
PROD_RESTIC_SOURCE_BUCKET=prod-snapshots-restic
PROD_RESTIC_DEST_BUCKET=emergent-template-restic

DEV_RESTIC_PASSWORD=
PROD_RESTIC_PASSWORD=

# --- Dev VM (runs the template creation script via `gcloud compute ssh`) ---
# Requires `gcloud auth login` on the machine running this backend.
VM_HOST=emergent-dev-vm-anshul
VM_ZONE=us-central1-a
TEMPLATE_SCRIPT_PATH=/home/sritam_emergent_sh/create_template_gcs.sh
